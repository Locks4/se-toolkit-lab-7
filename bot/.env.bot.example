# Telegram Bot Configuration
# Get this from @BotFather on Telegram
BOT_TOKEN=<your-telegram-bot-token-from-botfather>

# LMS Backend API Configuration
# URL of the LMS backend service
LMS_API_URL=http://localhost:42002
# API key for authenticating with the LMS backend
LMS_API_KEY=my-secret-api-key

# LLM API Configuration
# API key for the LLM service (Qwen Code or OpenRouter)
LLM_API_KEY=<your-qwen-api-key>
# Base URL for the LLM API
LLM_API_BASE_URL=http://localhost:42005/v1
# Model name to use for completions
LLM_API_MODEL=coder-model
